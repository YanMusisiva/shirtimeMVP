rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true; // 🔓 Tout le monde voit le catalogue de vêtements
      allow write: if request.auth != null; // 🔐 Seul votre compte Admin connecté peut modifier le catalogue
    }
  }
}
